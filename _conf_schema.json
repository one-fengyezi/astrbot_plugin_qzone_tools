{
  "enabled": {
    "description": "是否启用插件功能",
    "type": "bool",
    "default": true,
    "hint": "关闭后插件所有功能将不可用"
  },
  "memories": {
    "description": "持久化记忆存储列表（用户可通过WebUI查看和编辑）",
    "type": "list",
    "default": [],
    "items": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "default": "" },
        "user_id": { "type": "string", "default": "" },
        "content": { "type": "string", "default": "" },
        "tags": { "type": "list", "items": { "type": "string" }, "default": [] },
        "importance": { "type": "int", "default": 5 },
        "created_at": { "type": "string", "default": "" },
        "updated_at": { "type": "string", "default": "" }
      }
    }
  },
  "max_inject_memories": {
    "description": "聊天时自动注入上下文的最大记忆数量",
    "type": "int",
    "default": 5,
    "hint": "建议3-5条，过多会占用LLM上下文长度"
  },
  "memory_inject_enabled": {
    "description": "是否启用记忆自动注入",
    "type": "bool",
    "default": true,
    "hint": "开启后，每次对话会自动注入该用户最新的记忆到系统提示词"
  },
  "email_sender": {
    "description": "发件人QQ邮箱地址",
    "type": "string",
    "default": "",
    "hint": "例如：123456789@qq.com"
  },
  "email_authorization_code": {
    "description": "QQ邮箱授权码（不是登录密码）",
    "type": "string",
    "default": "",
    "hint": "请在QQ邮箱设置-账户中获取16位授权码",
    "obvious_hint": true
  },
  "email_smtp_server": {
    "description": "SMTP服务器（一般无需修改）",
    "type": "string",
    "default": "smtp.qq.com"
  },
  "email_smtp_port": {
    "description": "SMTP端口（SSL）",
    "type": "int",
    "default": 465
  },
  "search_max_chars": {
    "description": "搜索联系人返回的最大字符数，避免token消耗过多",
    "type": "int",
    "default": 800,
    "hint": "建议500-1000"
  },
  "search_enabled": {
    "description": "是否启用联系人搜索功能",
    "type": "bool",
    "default": true
  }
}